{
    "manifest_version": 3,
    "name": "TabSort for YouTube",
    "version": "1.0.0",
    "description": "Sort YouTube watch tabs by remaining time.",
    "permissions": [
      "tabs",
      "alarms",
      "webNavigation",
      "storage",
      "tabGroups"
    ],
    "host_permissions": [
      "*://*.youtube.com/*"
    ],
    "background": {
      "service_worker": "background/worker-entry.js",
      "type": "module"
    },
    "action": {
      "default_popup": "popup/popup.html",
      "default_title": "TabSort"
    },
    "content_scripts": [
      {
        "matches": ["*://*.youtube.com/watch*", "*://*.youtube.com/shorts*"],
        "js": ["content/youtube/runtime-entry.js"],
        "run_at": "document_end"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "content/youtube/page-runtime.js",
          "content/youtube/metadata.js",
          "content/youtube/live-status.js",
          "shared/constants.js",
          "shared/utils.js"
        ],
        "matches": ["*://*.youtube.com/*"]
      }
    ]
  }
