{
    "manifest_version": 3,
    "name": "TabSort for YouTube",
    "version": "1.0.0",
    "description": "Sort YouTube watch tabs by remaining time.",
    "permissions": [
      "tabs",
      "alarms",
      "webNavigation",
      "storage"
    ],
    "host_permissions": [
      "*://*.youtube.com/*"
    ],
    "background": {
      "service_worker": "background/worker-entry.js",
      "type": "module"
    },
    "action": {
      "default_popup": "popup/popup.html",
      "default_title": "TabSort"
    },
    "content_scripts": [
      {
        "matches": ["*://*.youtube.com/*"],
        "js": ["content/youtube/youtube-page-bootstrap.js"],
        "run_at": "document_end"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "content/youtube/controller.js",
          "content/youtube/content-script-ready-signal.js",
          "content/youtube/page-controller-config.js",
          "content/youtube/page-controller-state.js",
          "content/youtube/extension-runtime-bridge.js",
          "content/youtube/media-elements.js",
          "content/youtube/video-metrics-readiness.js",
          "content/youtube/video-details.js",
          "content/youtube/youtube-player-response.js",
          "content/youtube/live-status.js",
          "content/youtube/title-observer.js",
          "content/youtube/video-metrics.js",
          "shared/guards.js",
          "shared/video-duration.js",
          "shared/messages.js"
        ],
        "matches": ["*://*.youtube.com/*"]
      }
    ]
  }
